# =============================================================================
# Faith's Signature Organics — environment variables
# =============================================================================
# Copy this file to ".env.local" for local dev, and add the same variables in
# the Vercel dashboard (Project → Settings → Environment Variables) for prod.
#
# The site runs in DEMO MODE (built-in placeholder catalog, no real checkout)
# until BOTH Shopify variables below are filled in. As soon as they are set,
# the storefront pulls live products and routes "Check out" to real Shopify
# checkout — no code changes needed.
# -----------------------------------------------------------------------------

# Your Shopify store domain, e.g. faiths-organics.myshopify.com
# (You can also use a custom domain that is attached to the store.)
VITE_SHOPIFY_STORE_DOMAIN=

# Storefront API public access token.
# Shopify Admin → Settings → Apps and sales channels → Develop apps →
#   create/select an app → Storefront API → install → copy the
#   "Storefront API access token". This token is PUBLIC by design (it only
#   exposes data you grant via Storefront API scopes), so the VITE_ prefix
#   (which ships it to the browser) is safe.
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Optional — Storefront API version. Defaults to a recent stable version if unset.
VITE_SHOPIFY_API_VERSION=2024-10
